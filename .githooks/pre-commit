#!/usr/bin/env sh
set -e

staged=$(git diff --cached --name-only --diff-filter=ACM | grep '\.jl$' || true)
[ -z "$staged" ] && exit 0

echo "Running Runic formatter on staged .jl files..."

# Pass filenames via environment variable to avoid shell injection in the Julia -e string.
export RUNIC_STAGED="$staged"

julia --project=. -e '
using Runic
files = split(ENV["RUNIC_STAGED"], "\n"; keepempty = false)
any_changed = false
for f in files
    isfile(f) || continue
    original = read(f, String)
    formatted = Runic.format_string(original)
    if formatted != original
        write(f, formatted)
        println("  formatted: ", f)
        any_changed = true
    end
end
if any_changed
    println("\nSome files were reformatted. Re-stage them and commit again.")
    exit(1)
end
'
